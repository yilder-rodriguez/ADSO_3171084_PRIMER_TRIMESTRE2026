lo\n","            else:\n","              print(\"Debe ingresar un titulo valido \\n\")\n","\n","        def set_precio(self, nuevo_precio): # Este metodo me modifica el precio del libro\n","            if isinstance(nuevo_precio, (int, float)) and nuevo_precio >= 0:\n","              self.__precio = nuevo_precio\n","            else:\n","              print(\"Debe ingresar un precio que sea un numero valido \\n\")\n","\n","        # metodo adicional para mostrar la informacion completa del libro\n","        def mostrar_info(self):\n","            print(f\"Titulo: {self.__titulo}\")\n","            print(f\"Precio: ${self.__precio:,.2f}\") # aqui redondeo a dos decimas\n","\n","\n","# el metodo principal, experiencias de uduario\n","def main (): # Moved main outside the class\n","    print(\"\\n=== SISTEMA DE LIBROS ADSO  ===\")\n","\n","    #CREACION DEL OBJETA\n","    Libro1 = Libro(\"Goku se transfoma en consteño\",15000) # Corrected class instantiation\n","\n","    # Mostraremos la informacion principla osea los getter\n","    print(\"inormacion del libro \\n\")\n","    Libro1.mostrar_info() # Corrected method call\n","\n","    #M actualizacion del precio\n","    print(\"precjio actual del libo\\n\")\n","    print (f\"precio actuial: {Libro1.get_precio()}\")\n","\n","    # quiero que me salga un error enla actualizacion del typado del Precio del libro\n","    Libro1.set_precio(\"1200\")\n","    print (f\"el nuevo precio actualizado es: {Libro1.get_precio()}\")\n","\n","    print(\"Informacion principal nueva del libero\\n\")\n","    Libro1.mostrar_info()\n","\n","    print(\"=== FIN DEL PROGRAMA ===\")\n","if __name__ == \"__main__\":\n","    main()\n"]}]}